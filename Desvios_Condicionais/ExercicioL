funcao inicio()
	{
		inteiro numero_conta
		real saldo, debito, credito, saldo_atual
		
		escreva("Número da conta: ")
		leia(numero_conta)
		
		escreva("Saldo: ")
		leia(saldo)
		
		escreva("Débito: ")
		leia(debito)
		
		escreva("Crédito: ")
		leia(credito)
		
		saldo_atual = saldo - debito + credito
		
		escreva("Saldo atual: ", saldo_atual, "\n")
		
		se (saldo_atual >= 0) {
		escreva("Saldo Positivo")
		} senao {
		escreva("Saldo Negativo")
		}

	}
}
