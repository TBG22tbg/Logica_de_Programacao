programa
{
	
	funcao inicio()
	{
		inteiro valor1, valor2, div

		escreva("Informe o primeiro valor: ")
			leia(valor1)

		faca 
		{

			escreva("Informe o segundo valor: ")
			leia(valor2)

		}
		enquanto (valor2 <= 0)
		div = valor1 / valor2
		escreva("A divisão dos número é: ", div)

	}
}
