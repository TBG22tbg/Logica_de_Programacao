programa
{
	
	funcao inicio()
	{
		inteiro c
		real f

		para(c=10; c<=100; c=c+10) {

			f= (9*c / 5) + 32
			escreva("Celsius: ", c, "c°; Fahrenheit: ", f, "°f\n")
			}
	}
}
